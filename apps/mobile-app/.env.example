# Configuracoes do app Expo (mobile-app)
#
# Copie este arquivo para .env (que e gitignored) e preencha os valores.
# Variaveis com prefixo EXPO_PUBLIC_ sao injetadas no bundle client-side.

# URL base da API. Em producao aponta para o painel.
EXPO_PUBLIC_API_URL=https://painel.letras.cloud/api/v1

# Sentry — projeto letras-mobile na org spin-xs.
# Esse DSN e public-safe (embute no bundle do app).
# Auth token de upload de source maps NAO entra aqui — vai em variavel
# de ambiente do CI/CD, com escopo project:releases.
EXPO_PUBLIC_SENTRY_DSN=https://your-public-dsn@oXXXXXXXXX.ingest.us.sentry.io/YYYYYYYYY
